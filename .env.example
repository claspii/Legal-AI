# Copy this file to .env and fill in your actual values before running the application.

# ── LLM PROVIDER CONFIGURATION ──────────────────────────────────────────
# LLM Provider: "gemini", "openai", or using OpenRouter models
LLM_PROVIDER=gemini

# ── GOOGLE GEMINI / VERTEX AI CONFIGURATION ─────────────────────────────
# Path to your Google Service Account JSON file (e.g. key.json)
GOOGLE_APPLICATION_CREDENTIALS=key.json
# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id_here
# Vertex AI API Location (e.g. global, us-central1)
GOOGLE_CLOUD_LOCATION=global
# Use Vertex AI SDK (True/False)
GOOGLE_GENAI_USE_VERTEXAI=True
# Alternative: Gemini API Key (Direct API Access)
GOOGLE_API_KEY=your_google_api_key_here

# ── OPENAI CONFIGURATION ────────────────────────────────────────────────
# OpenAI API Key (Required if using OpenAI models directly)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── OPENROUTER CONFIGURATION ────────────────────────────────────────────
# OpenRouter API Key (Required for openrouter.py models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── HUGGING FACE CONFIGURATION ──────────────────────────────────────────
# Hugging Face Token (Needed for private models or Hub downloads)
HF_TOKEN=your_hugging_face_token_here

# ── VECTOR DB (CHROMADB) CONFIGURATION ──────────────────────────────────
# Directory where ChromaDB indexes are persisted
CHROMA_PERSIST_DIR=./chroma_db
# Collection name inside ChromaDB
CHROMA_COLLECTION=legal_documents
# Embedding Model to use
EMBEDDING_MODEL=BAAI/bge-m3

# ── GRAPH DATABASE (NEO4J) CONFIGURATION ────────────────────────────────
# Connection URI for Neo4j Database
NEO4J_URI=bolt://localhost:7687
# Username for Neo4j login
NEO4J_USER=neo4j
# Password for Neo4j login
NEO4J_PASSWORD=your_neo4j_password_here
# Database name inside Neo4j
NEO4J_DATABASE=neo4j

# ── RAG GRAPH RETRIEVAL CONFIGURATION ───────────────────────────────────
# Enable Knowledge Graph context augmentation (true/false)
ENABLE_GRAPH_RETRIEVAL=true
# Max steps to traverse references from seed nodes
GRAPH_EXPAND_HOPS=2
# Number of top candidate regulations to keep from graph search
GRAPH_TOP_M=5
# Write RAG graph queries to logs for inspection (true/false)
GRAPH_RETRIEVAL_LOG_ENABLED=true
GRAPH_RETRIEVAL_LOG_PATH=./logs/graph_retrieval.log

# ── INGESTION & TEXT SPLITTING CONFIGURATION ───────────────────────────
# Directory containing raw legal text files (e.g. .txt files)
DOCS_DIR=./data
# Chunk size for text splitting
CHUNK_SIZE=1000
# Chunk overlap for text splitting
CHUNK_OVERLAP=200
# Max chunk size
MAX_CHUNK_SIZE=10000

# ── HYBRID FUSION RETRIEVAL PARAMETERS ─────────────────────────────────
# Number of total chunks retrieved by RAG
TOP_K=5
# Minimum similarity score required for vector matches
SIMILARITY_THRESHOLD=0.3
# LLM Cache directory
LLM_CACHE_DIR=./.llm_cache

# ── SERVER CONFIGURATION ────────────────────────────────────────────────
# HOST IP for the FastAPI application to bind
HOST=0.0.0.0
# Port for the FastAPI server to listen on
PORT=7860
